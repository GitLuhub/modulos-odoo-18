<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_task_extended_tree" model="ir.ui.view">
        <field name="name">project.task.extended.tree</field>
        <field name="model">project.task.extended</field>
        <field name="arch" type="xml">
            <list>
                <field name="task_id"/>
                <field name="priority" widget="priority"/>
                <field name="estimated_hours"/>
                <field name="actual_hours"/>
                <field name="remaining_hours"/>
                <field name="deadline"/>
                <field name="progress_percentage" widget="progressbar"/>
            </list>
        </field>
    </record>

    <record id="view_project_task_extended_form" model="ir.ui.view">
        <field name="name">project.task.extended.form</field>
        <field name="model">project.task.extended</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="task_id"/>
                        <field name="priority" widget="priority"/>
                        <field name="tag_ids" widget="many2many_tags"/>
                    </group>
                    <group string="Time Tracking" col="3">
                        <field name="estimated_hours"/>
                        <field name="actual_hours"/>
                        <field name="remaining_hours" readonly="1"/>
                    </group>
                    <group string="Priority &amp; Deadlines">
                        <field name="deadline"/>
                        <field name="is_overdue" readonly="1"/>
                    </group>
                    <group string="Progress">
                        <field name="progress_percentage" widget="progressbar"/>
                    </group>
                    <group string="Checklist">
                        <field name="checklist_ids">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="is_done"/>
                            </list>
                        </field>
                        <button name="action_complete_checklist" 
                                string="Mark All Complete" 
                                type="object" 
                                class="oe_highlight"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_project_task_extended" model="ir.actions.act_window">
        <field name="name">Extended Tasks</field>
        <field name="res_model">project.task.extended</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_project_extended"
              name="Extended Tasks"
              action="action_project_task_extended"
              parent="project.menu_project_config"
              sequence="100"/>
</odoo>
