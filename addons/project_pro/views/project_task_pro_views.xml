<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista formulario para deadline y horas -->
    <record id="view_task_form_pro_hours" model="ir.ui.view">
        <field name="name">project.task.form.pro.hours</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="priority" eval="15"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="tag_ids" widget="many2many_tags" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='date_deadline']" position="after">
                <field name="deadline" optional="show"/>
                <field name="is_overdue" optional="show" invisible="1"/>
                <field name="estimated_hours" optional="show"/>
                <field name="actual_hours" optional="show"/>
                <field name="planned_hours" optional="show"/>
                <field name="remaining_hours" optional="show"/>
            </xpath>
        </field>
    </record>
    <!-- Vista kanban para project.task -->
    <record id="view_task_kanban_pro" model="ir.ui.view">
        <field name="name">project.task.kanban.pro</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//t[@t-name='card']/main/field[@name='displayed_image_id']" position="after">
                <div t-if="record.progress_percentage.raw_value > 0" class="mt-2">
                    <field name="progress_percentage" widget="progressbar"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Acción para etiquetas -->
    <record id="action_project_task_tag_pro" model="ir.actions.act_window">
        <field name="name">Task Tags Pro</field>
        <field name="res_model">project.task.tag.pro</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menú de configuración -->
    <menuitem id="menu_project_pro_config"
              name="Project Pro"
              parent="project.menu_project_config"
              sequence="90"/>

    <menuitem id="menu_project_task_tag_pro"
              name="Tags Pro"
              action="action_project_task_tag_pro"
              parent="menu_project_pro_config"
              sequence="10"/>
</odoo>
