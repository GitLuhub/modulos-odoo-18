<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extender vista formulario de tareas -->
    <record id="view_task_form_inherit_pro" model="ir.ui.view">
        <field name="name">project.task.form.inherit.pro</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="tag_ids" widget="many2many_tags" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='date_deadline']" position="after">
                <field name="deadline" optional="show"/>
                <field name="is_overdue" optional="show" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='planned_hours']" position="after">
                <field name="estimated_hours" optional="show"/>
                <field name="actual_hours" optional="show"/>
                <field name="remaining_hours" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='progress']" position="after">
                <field name="progress_percentage" widget="progressbar" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='description']" position="before">
                <group string="Checklist" name="checklist_group">
                    <field name="checklist_ids" colspan="2" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="is_done"/>
                        </list>
                    </field>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Extender vista kanban de tareas -->
    <record id="view_task_kanban_inherit_pro" model="ir.ui.view">
        <field name="name">project.task.kanban.inherit.pro</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_project_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('o_kanban_record_subtitle')]" position="inside">
                <t t-if="record.progress_percentage.raw_value > 0">
                    <div class="mt-1">
                        <field name="progress_percentage" widget="progressbar"/>
                    </div>
                </t>
            </xpath>
        </field>
    </record>

    <!-- Acción para etiquetas -->
    <record id="action_project_task_tag_pro" model="ir.actions.act_window">
        <field name="name">Task Tags Pro</field>
        <field name="res_model">project.task.tag.pro</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menú de configuración -->
    <menuitem id="menu_project_pro_config"
              name="Project Pro"
              parent="project.menu_project_config"
              sequence="90"/>

    <menuitem id="menu_project_task_tag_pro"
              name="Tags Pro"
              action="action_project_task_tag_pro"
              parent="menu_project_pro_config"
              sequence="10"/>
</odoo>
